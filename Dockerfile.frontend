FROM node:20-alpine

WORKDIR /app

COPY web-dashboard/package*.json ./
RUN npm install

COPY web-dashboard/ .
# VERSION is read by vite.config.ts (resolve(__dirname, '../VERSION') fails in Docker; use ./VERSION)
COPY VERSION ./VERSION

EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]

#!/usr/bin/env bash
set -euo pipefail

remote_name="${1:-origin}"
remote_url="${2:-}"
zero_sha="0000000000000000000000000000000000000000"

repo_root="$(git rev-parse --show-toplevel)"
generator_script="${repo_root}/tools/release_notes/generate_release_notes.py"

if [[ ! -f "${generator_script}" ]]; then
  echo "[pre-push] Missing release notes generator: ${generator_script}" >&2
  exit 1
fi

block_push=0

while read -r local_ref local_sha remote_ref remote_sha; do
  [[ -z "${local_ref:-}" ]] && continue

  if [[ "${local_ref}" != "refs/heads/master" || "${remote_ref}" != "refs/heads/master" ]]; then
    continue
  fi

  if [[ "${local_sha}" == "${remote_sha}" ]]; then
    continue
  fi

  # For release-notes commits, the file is named after the parent (the content commit)
  if git log -1 --format=%s "${local_sha}" 2>/dev/null | grep -qE "docs\(release\)|release notes"; then
    parent_sha="$(git rev-parse "${local_sha}^" 2>/dev/null)"
    notes_rel_path="release-notes/master-${parent_sha:0:12}.md"
  else
    notes_rel_path="release-notes/master-${local_sha:0:12}.md"
  fi

  if git cat-file -e "${local_sha}:${notes_rel_path}" 2>/dev/null; then
    echo "[pre-push] Release notes found in commit tree: ${notes_rel_path}" >&2
    continue
  fi

  echo "[pre-push] Missing release notes for push to master." >&2
  echo "[pre-push] Remote: ${remote_name} (${remote_url})" >&2

  if [[ "${remote_sha}" == "${zero_sha}" ]]; then
    python3 "${generator_script}" \
      --head "${local_sha}" \
      --target-branch "master" \
      --output "${repo_root}/${notes_rel_path}"
  else
    python3 "${generator_script}" \
      --base "${remote_sha}" \
      --head "${local_sha}" \
      --target-branch "master" \
      --output "${repo_root}/${notes_rel_path}"
  fi

  cat >&2 <<EOF
[pre-push] Generated release notes at: ${notes_rel_path}
[pre-push] Review and commit this file before pushing to master:
  git add ${notes_rel_path}
  git commit -m "docs(release): add release notes for ${local_sha:0:12}"
  git push ${remote_name} master
EOF
  block_push=1
done

if [[ "${block_push}" -eq 1 ]]; then
  exit 1
fi

exit 0
